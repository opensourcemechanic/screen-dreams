# Screen Dreams - UVX Environment Configuration
# Copy this to .env and customize for your setup

# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=True
SECRET_KEY=your-secret-key-change-this-in-production

# Database Configuration (SQLite - works out of the box)
DATABASE_URL=sqlite:///screen_dreams.db

# AI Provider Configuration
# Choose: ollama, openai, anthropic, none
AI_PROVIDER=ollama

# Ollama Configuration (for local AI)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=tinyllama
OLLAMA_VERIFY_SSL=False

# OpenAI Configuration (if using OpenAI)
# OPENAI_API_KEY=your-openai-api-key-here
# OPENAI_MODEL=gpt-3.5-turbo

# Anthropic Configuration (if using Claude)
# ANTHROPIC_API_KEY=your-anthropic-api-key-here
# ANTHROPIC_MODEL=claude-3-sonnet-20240229

# Application Paths
UPLOAD_FOLDER=./uploads
SCREENPLAY_FOLDER=./screenplays

# Server Configuration
HOST=0.0.0.0
PORT=5000

# Redis Configuration (optional - for session storage)
# REDIS_URL=redis://localhost:6379/0
# RATELIMIT_STORAGE_URL=redis://localhost:6379/0
