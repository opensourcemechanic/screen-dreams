# Docker Environment Configuration
# Copy this to .env and configure your settings

# Security Keys (Generate these!)
SECRET_KEY=your-256-character-secret-key-here-change-this-in-production
DB_PASSWORD=your-secure-database-password-here

# Flask Configuration
FLASK_ENV=production
FLASK_DEBUG=False

# AI Provider Configuration
# Choose: ollama, openai, anthropic, ionos, scaleway
AI_PROVIDER=ollama

# Ollama Configuration (for local AI)
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama2
OLLAMA_VERIFY_SSL=false

# OpenAI Configuration (optional)
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-3.5-turbo

# Anthropic Configuration (optional)
ANTHROPIC_API_KEY=your-anthropic-api-key
ANTHROPIC_MODEL=claude-3-sonnet-20240229

# IONOS AI Configuration (optional)
IONOS_API_KEY=your-ionos-api-key
IONOS_MODEL=llama-3.3-70b

# Scaleway AI Configuration (optional)
SCALEWAY_API_KEY=your-scaleway-api-key
SCALEWAY_MODEL=llama-3.3-70b

# Email Configuration (optional)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password

# Security Configuration
SESSION_COOKIE_SECURE=True
SESSION_COOKIE_HTTPONLY=True
SESSION_COOKIE_SAMESITE=Lax

# File Upload Configuration
MAX_CONTENT_LENGTH=104857600  # 100MB
UPLOAD_FOLDER=/app/uploads

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=/var/log/screen-dreams/app.log

# Rate Limiting
RATELIMIT_STORAGE_URL=redis://redis:6379/0

# Content Security Policy
CSP_DEFAULT_SRC='self'
CSP_SCRIPT_SRC='self' 'unsafe-inline'
CSP_STYLE_SRC='self' 'unsafe-inline'
CSP_IMG_SRC='self' data:
CSP_FONT_SRC='self'

# Email Settings
SECURITY_EMAIL_SENDER=noreply@screendreams.com
